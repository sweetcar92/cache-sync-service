#!/usr/bin/env python
# vim:fileencoding=utf-8
from __future__ import absolute_import, division, print_function, unicode_literals

import json
import re
from datetime import date

from calibre.web.feeds.news import BasicNewsRecipe


class FeedMod01(BasicNewsRecipe):
    title = 'Le Monde'
    __author__ = 'veezh, Martin Villard, Kabonix'
    description = 'Data feed 01'
    publisher = 'Société Editrice du Monde'
    publication_type = 'newspaper'
    language = 'fr'
    encoding = 'utf-8'

    timefmt = ' - %d/%m %Hh%M'
    oldest_article = 1
    no_stylesheets = True
    remove_attributes = ['style', 'height', 'width']
    ignore_duplicate_articles = {'title', 'url'}
    reverse_article_order = True
    remove_empty_feeds = True

    auto_cleanup = False
    delay = 1

    compress_news_images = False
    scale_news_images_to_device = False
    scale_news_images = None

    browser_user_agent = 'LeMonde/9.20.1 (Android; 14)'

    def get_browser(self, *args, **kwargs):
        br = BasicNewsRecipe.get_browser(self, *args, **kwargs)
        br.addheaders = [
            ('User-Agent', self.browser_user_agent),
            ('X-Lmd-Token', 'TWPLMOLMO'),
            ('Accept', 'application/json')
        ]
        return br

    def get_article_url(self, article):
        url = BasicNewsRecipe.get_article_url(self, article)
        match = re.search(r'_(\d+)_\d+\.html', url)
        if match:
            article_id = match.group(1)
            return f'https://apps.lemonde.fr/aec/v1/premium-android-phone/article/{article_id}'
        return url

    def preprocess_raw_html(self, raw_html, url):
        if '/aec/v1/' in url:
            try:
                data = json.loads(raw_html)
                content = data['template_vars']['content']
                title = data['template_vars'].get('seo_title', 'Le Monde')
                content = content.replace('%7B%7Bwidth%7D%7D', '1000').replace('{{width}}', '1000')
                content = content.replace('%7B%7Bheight%7D%7D', '600').replace('{{height}}', '600')
                return f'<html><head><title>{title}</title></head><body>{content}</body></html>'
            except Exception:
                return raw_html
        return raw_html

    def get_cover_url(self):
        cover_id = date.today().strftime('%Y%m%d')
        return 'https://www.lemonde.fr/thumbnail/journal/' + cover_id + '/1000/1490'

    keep_only_tags = [
        dict(name='h1', attrs={'class': ['heading', 'article__title']}),
        dict(name='div', attrs={'class': ['kicker', 'article__desc']}),
        dict(name='div', attrs={'class': ['article_content', 'article__content']}),
        dict(name='figure')
    ]

    remove_tags = [
        dict(name='div', attrs={'class': [
            'see-also-container', 'inread-container', 'premium-container',
            'restricted-reading', 'offer-container', 'authors-container',
            'js-init-line-clamp', 'bloc-reactions', 'meta__publisher'
        ]}),
        dict(name=['aside', 'footer', 'button', 'svg', 'script', 'style', 'video'])
    ]

    extra_css = '''
        body { font-size: 1em; line-height: 1.4; margin: 0; padding: 0; }
        h1, h1.calibre_title, .heading, .article__title { font-size: 1.2em !important; font-weight: bold; line-height: 1.2; margin-top: 0.2em; margin-bottom: 0.6em; text-align: left; }
        h2 { font-size: 1.1em; font-weight: bold; margin-top: 0.9em; margin-bottom: 0.4em; }
        h3 { font-size: 1.05em; font-weight: bold; margin-top: 0.8em; margin-bottom: 0.4em; }
        .kicker, .article__desc { font-size: 0.95em; font-style: italic; font-weight: bold; color: #333; margin-bottom: 1em; }
        p { font-size: 0.95em; line-height: 1.4; text-align: justify; margin-top: 0; margin-bottom: 0.8em; }
        figure, div.figure { margin: 0.6em 0; padding: 0; text-align: center; }
        figure div, figure p { margin: 0; padding: 0; }
        img { display: block; margin: 0.4em auto; width: 80%; max-width: 100%; height: auto; }
        figcaption, .caption { display: block; margin-top: 0.2em; font-size: 0.8em; line-height: 1.25; color: #555; font-style: italic; text-align: center; }
    '''

    def parse_index(self):
        feeds = BasicNewsRecipe.parse_index(self)
        filtered_feeds = []
        for feed_title, articles in feeds:
            valid_articles = []
            for a in articles:
                title = a.get('title', '').strip()
                t_upper = title.upper()
                if t_upper.startswith(('EN DIRECT', 'DIRECT', '[EN DIRECT]', 'LIVE')) or 'EN DIRECT' in t_upper or 'DIRECT :' in t_upper:
                    self.report_progress(0, f"Ignoré (EN DIRECT): {title}")
                    continue
                valid_articles.append(a)
            if valid_articles:
                filtered_feeds.append((feed_title, valid_articles))
        return filtered_feeds

    def preprocess_html(self, soup):
        for tag in soup.find_all(['img', 'figure', 'picture', 'div', 'p', 'span']):
            for attr in ['width', 'height', 'style', 'aspect-ratio']:
                if tag.has_attr(attr):
                    del tag[attr]

        for img in soup.find_all('img'):
            if img.has_attr('data-src'):
                img['src'] = img['data-src']

            if img.has_attr('srcset'):
                try:
                    candidates = img['srcset'].split(',')
                    url = candidates[-1].strip().split(' ')[0]
                    if url.startswith('http'):
                        img['src'] = url
                except Exception:
                    pass

            for attr in ['srcset', 'data-srcset', 'data-src', 'loading']:
                if img.has_attr(attr):
                    del img[attr]

        return soup

    feeds = [
        ('À la une', 'https://www.lemonde.fr/rss/une.xml'),
        ('Économie', 'https://www.lemonde.fr/economie/rss_full.xml'),
        ('International', 'https://www.lemonde.fr/international/rss_full.xml'),
        ('Planète', 'https://www.lemonde.fr/planete/rss_full.xml'),
        ('M le Mag', 'https://www.lemonde.fr/m-le-mag/rss_full.xml')
    ]
