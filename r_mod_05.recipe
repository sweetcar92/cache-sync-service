#!/usr/bin/env python
# vim:fileencoding=utf-8
import json
from html5_parser import parse
from calibre.web.feeds.news import BasicNewsRecipe


class FeedMod05(BasicNewsRecipe):
    title = 'The Washington Post'
    timefmt = ' - %d/%m %Hh%M'
    __author__ = 'unkn0wn'
    description = 'Data feed 05'
    publisher = 'The Washington Post Company'
    category = 'news, politics, USA'
    no_stylesheets = True
    use_embedded_content = False
    encoding = 'utf-8'
    language = 'en_US'
    remove_attributes = ['style', 'height', 'width']
    publication_type = 'newspaper'
    resolve_internal_links = True
    compress_news_images = False
    scale_news_images_to_device = False
    scale_news_images = None

    extra_css = '''
        body { font-size: 1em; line-height: 1.4; margin: 0; padding: 0; }
        h1, h1.calibre_title, .article-title, .title { font-size: 1.2em !important; font-weight: bold; line-height: 1.2; margin-top: 0.2em; margin-bottom: 0.6em; text-align: left; }
        h2 { font-size: 1.1em; font-weight: bold; margin-top: 0.9em; margin-bottom: 0.4em; }
        h3 { font-size: 1.05em; font-weight: bold; margin-top: 0.8em; margin-bottom: 0.4em; }
        p { font-size: 0.95em; line-height: 1.4; text-align: justify; margin-top: 0; margin-bottom: 0.8em; }
        figure, div.figure { margin: 0.6em 0; padding: 0; text-align: center; }
        figure div, figure p { margin: 0; padding: 0; }
        img { display: block; margin: 0.4em auto; width: 80%; max-width: 100%; height: auto; }
        figcaption, .caption { display: block; margin-top: 0.2em; font-size: 0.8em; line-height: 1.25; color: #555; font-style: italic; text-align: center; }
    '''

    def preprocess_html(self, soup):
        return soup

    def get_browser(self, *args, **kwargs):
        kwargs['user_agent'] = (
            'Mozilla/5.0 (compatible; Googlebot/2.1; +http://www.google.com/bot.html)'
        )
        br = BasicNewsRecipe.get_browser(self, *args, **kwargs)
        br.addheaders += [
            ('Referer', 'https://www.google.com/'),
            ('X-Forwarded-For', '66.249.66.1'),
        ]
        return br

    def parse_index(self):
        soup = self.index_to_soup('https://www.washingtonpost.com/todays_paper/updates/')

        feeds = []

        for div in soup.findAll('section', attrs={'id': True}):
            secname = self.tag_to_string(div.find('label')).strip()
            self.log(secname)
            articles = []
            for a in div.findAll('a', href=True):
                url = a['href']
                title = self.tag_to_string(a).strip()
                if not title or not url:
                    continue
                t_upper = title.upper()
                if t_upper.startswith(('EN DIRECT', 'DIRECT', '[EN DIRECT]', 'LIVE')) or 'EN DIRECT' in t_upper:
                    continue
                self.log('\t', title)
                self.log('\t\t', url)
                articles.append({'title': title, 'url': url})
            if articles:
                feeds.append((secname, articles))
        return feeds

    def preprocess_raw_html(self, raw, url):
        root = parse(raw)
        if '/interactive/' in url:
            return ('<html><body><article><h1>' + root.xpath('//h1')[0].text + '</h1><em>'
                    'This article is supposed to be read in a browser.'
                    '</em></article></body></html>')
        m = root.xpath('//script[@id="__NEXT_DATA__"]')

        data = json.loads(m[0].text)
        data = data['props']['pageProps']['globalContent']

        text = data.get('label', {}).get('basic', {}).get('text', '')
        label = f'<p class="time">{text}</p>' if text else ''
        title = '<h1>' + data['headlines']['basic'] + '</h1>'
        subhead = '<h3 class="subhead">' + data['description'].get('basic', '') + '</h3>'

        author = ''
        if 'credits' in data:
            author = (
                '<div><span class="auth">'
                + 'By '
                + ', '.join(x['name'] for x in data['credits']['by'])
                + '</span> | <span class="time">'
                + data['publish_date'][:-14]
                + '</span></div>'
            )

        body = ''
        for x in data['content_elements']:
            if x['type'] == 'text':
                body += '<p>' + x['content'] + '</p>'
            elif x['type'] == 'list':
                body += '<ul>'
                for li in x['items']:
                    if li.get('content', '') != '':
                        body += f'<li>{li["content"]}</li>'
                body += '</ul>'

        return (
            '<html><body><div>'
            + label
            + title
            + subhead
            + author
            + body
            + '</div></body></html>'
        )
